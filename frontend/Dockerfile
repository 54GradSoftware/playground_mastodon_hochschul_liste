FROM node:alpine as builder

ARG VITE_DATA_SERVER_URL
ARG VITE_ENABLE_PLAUSIBLE_ANALYTICS
ARG VITE_PLAUSIBLE_ANALYTICS_DOMAIN
ARG VITE_MAPBOX_ACCESS_TOKEN

ENV VITE_DATA_SERVER_URL=$VITE_DATA_SERVER_URL
ENV VITE_ENABLE_PLAUSIBLE_ANALYTICS=$VITE_ENABLE_PLAUSIBLE_ANALYTICS
ENV VITE_PLAUSIBLE_ANALYTICS_DOMAIN=$VITE_PLAUSIBLE_ANALYTICS_DOMAIN
ENV VITE_MAPBOX_ACCESS_TOKEN=$VITE_MAPBOX_ACCESS_TOKEN

WORKDIR /app
ADD . .

RUN npm ci && npm run build

# build nginx webserver
FROM nginx:alpine

EXPOSE 3001

ADD ./nginx.conf /etc/nginx/nginx.conf
COPY --from=builder /app/dist /var/www/html

CMD ["nginx", "-g", "daemon off;"]
